  "root_cause": {
    "service": "cache-layer",
    "description": "cache-layer v2.1.0 introduced a config change 'cache.eviction_policy=none' that disabled all key eviction. Under afternoon traffic load, the cache grew without bound until the process was OOM-killed. With cache-layer down, all services relying on it for session data (user-service, api-gateway) and query caching (order-service, inventory-service) experienced cascading failures. The flood of uncached direct DB reads overwhelmed order-db, amplifying the outage.",
    "keywords": ["cache-layer", "eviction", "memory", "OOM", "cache.eviction_policy", "none", "v2.1.0", "session", "unbounded"]
  },
